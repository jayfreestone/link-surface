{
  "name": "link-surface",
  "version": "0.1.0",
  "description": "Progressively expand a real anchor's plain-click target across otherwise inert content.",
  "type": "module",
  "packageManager": "npm@11.11.0",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./auto": {
      "types": "./dist/auto.d.ts",
      "default": "./dist/auto.js"
    },
    "./global": "./dist/link-surface.iife.js",
    "./styles.css": "./styles.css",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/link-surface.iife.js",
  "jsdelivr": "./dist/link-surface.iife.js",
  "customElements": "custom-elements.json",
  "files": [
    "dist",
    "styles.css",
    "custom-elements.json",
    "CHANGELOG.md"
  ],
  "sideEffects": [
    "./dist/auto.js",
    "./styles.css"
  ],
  "scripts": {
    "build": "tsdown && npm run manifest",
    "dev": "vite",
    "manifest": "cem analyze",
    "site": "npm run build && vite build",
    "serve": "npm run site && vite preview",
    "test": "npm run test:ssr && npm run test:browser",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "test:ssr": "vitest run --config vitest.config.ts",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm run test && npm run build",
    "prepack": "npm run verify"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jayfreestone/link-surface.git"
  },
  "author": {
    "name": "Jay Freestone",
    "email": "mail@jayfreestone.com",
    "url": "https://www.jayfreestone.com/"
  },
  "license": "0BSD",
  "bugs": {
    "url": "https://github.com/jayfreestone/link-surface/issues"
  },
  "homepage": "https://github.com/jayfreestone/link-surface#readme",
  "keywords": [
    "anchor",
    "card",
    "custom-element",
    "link",
    "progressive-enhancement",
    "web-component"
  ],
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@vitest/browser-playwright": "^4.0.14",
    "playwright": "^1.57.0",
    "tsdown": "^0.16.8",
    "typescript": "^5.9.3",
    "vite": "^8.1.4",
    "vitest": "^4.0.14"
  }
}
